# Copy this file to .env.cloud on your server and fill in real values.

# Application version (overridden by Dockerfile / docker-compose).
CLOUD_APP_VERSION=1.0.1

# Public port exposed by Docker on the cloud server.
CLOUD_BIND_HOST=127.0.0.1
CLOUD_HTTP_PORT=8787

# Public HTTPS URL of this cloud backend.
# Example: https://cloud.your-domain.com
CLOUD_PUBLIC_URL=

# Token lifetime settings.
CLOUD_TOKEN_TTL_SECONDS=2592000
CLOUD_RESET_TOKEN_TTL_SECONDS=1800
CLOUD_EMAIL_TOKEN_TTL_SECONDS=86400

# Production must keep this disabled.
# When enabled, verification/reset tokens are returned in API responses for local testing.
CLOUD_EMAIL_DEV_MODE=0

# Initial admin console account.
# Used only when the database has no admin user yet.
CLOUD_ADMIN_USERNAME=admin
CLOUD_ADMIN_PASSWORD=admin
CLOUD_ADMIN_SESSION_TTL_SECONDS=604800

# Maximum single user config payload size in bytes.
CLOUD_CONFIG_MAX_BYTES=1048576

# SMTP mail sender. Use an app password, not your personal mailbox password.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=1

# Optional encrypted cloud backup target. Compatible with Cloudflare R2, Aliyun OSS S3 API, AWS S3 and MinIO.
# Provider: custom_s3 | cloudflare_r2 | aliyun_oss | aws_s3 | minio
CLOUD_BACKUP_PROVIDER=custom_s3
CLOUD_BACKUP_ENDPOINT=
CLOUD_BACKUP_REGION=auto
# Addressing style: auto | path | virtual
# R2 usually uses path; Aliyun OSS usually uses virtual.
CLOUD_BACKUP_ADDRESSING_STYLE=auto
CLOUD_BACKUP_BUCKET=
CLOUD_BACKUP_PREFIX=infinite-canvas/backups
CLOUD_BACKUP_ACCESS_KEY_ID=
CLOUD_BACKUP_SECRET_ACCESS_KEY=
CLOUD_BACKUP_ENCRYPTION_PASSPHRASE=
CLOUD_BACKUP_RETENTION_COUNT=14
